/* Court visualization styles */

/* Court Map */
.court-map {
    height: 18;
    width: 36;
    border: tall $primary;
    padding: 0;
}

/* Shooting Chart (spatial) */
.court-shooting-chart {
    height: 16;
    width: 32;
    padding: 0;
}

/* Legacy Shooting Chart */
.shooting-chart {
    height: auto;
    width: auto;
    padding: 1;
}

.zone-hot {
    color: #e74c3c;
}

.zone-cold {
    color: #3498db;
}

.zone-neutral {
    color: $text-muted;
}
