/* DataTable styles for box scores and standings */

DataTable {
    height: auto;
}

DataTable > .datatable--header {
    text-style: bold;
    color: $text;
    background: $primary-background;
}

DataTable > .datatable--cursor {
    background: $accent;
    color: $text;
}

/* Box score specific */
.box-score-table {
    height: auto;
    max-height: 20;
    margin: 1 0;
}

/* Standings table */
.standings-table {
    height: auto;
    max-height: 18;
    margin: 1 0;
}
