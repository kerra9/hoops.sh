/* Broadcast scoreboard styles */

BroadcastScoreboard {
    height: 3;
    dock: top;
    background: $primary-background;
    padding: 0 2;
}

BroadcastScoreboard .scoreboard-strip {
    height: 1;
    width: 100%;
    text-align: center;
}

BroadcastScoreboard .team-score {
    text-style: bold;
}

BroadcastScoreboard .clock {
    text-style: bold;
}

BroadcastScoreboard .shot-clock {
    color: #f1c40f;
}

BroadcastScoreboard .period {
    color: $text-muted;
}
